# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (psycopg3 driver)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/metis_intelligence

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# Optional: set this to route API calls through an OpenAI-compatible proxy.
# GenSpark LLM gateway example (requires a GenSpark API key):
#   OPENAI_BASE_URL=https://www.genspark.ai/api/llm_proxy/v1
# Leave commented out to use the official OpenAI endpoint directly.
# OPENAI_BASE_URL=

# Which model to use.  gpt-5-mini is fast and cheap; swap to gpt-5 for better quality.
# When using the GenSpark proxy the supported models are:
#   gpt-5-nano, gpt-5-mini, gpt-5, gpt-5.1, gpt-5.2, gpt-5-codex
LLM_MODEL=gpt-5-mini

# Set to true to skip OpenAI calls entirely and use the built-in rich mock report.
# Useful for local development and CI when no API key is available.
LLM_MOCK_MODE=false

# ── LLM provider / model-tier / cost controls ─────────────────────────────────
# LLM provider to use.  Currently only "openai" is implemented.
# Future values: "anthropic", "gemini"
LLM_PROVIDER=openai

# Model tier selector — maps to a model name inside the provider registry.
# cheap   → gpt-5-nano  (lowest cost, fastest)
# default → gpt-5-mini  (recommended for most workloads)
# premium → gpt-5       (best quality, higher cost)
LLM_MODEL_TIER=default

# Hard cap on completion tokens per LLM request.
# Actual output for the 5-insight / 4-5-recommendation schema is 400-580 tokens.
# 650 gives a ~15% safety buffer. Raise to 900+ only if you add more output fields.
# Use a lower value (e.g. 500) with the compact v2 prompt for maximum cost savings.
LLM_MAX_TOKENS=650

# Sampling temperature: 0.0 = fully deterministic, 1.0 = highly creative.
# 0.4 balances consistency with natural, readable text.
LLM_TEMPERATURE=0.4

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON array of allowed origins.  Use ["*"] for open access in development.
# In production set this to your frontend domain:  ["https://app.yourdomain.com"]
CORS_ORIGINS=["*"]

# ── Logging ───────────────────────────────────────────────────────────────────
# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
